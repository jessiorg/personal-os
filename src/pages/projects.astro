---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Projects - Kanay Company OS">
  <main>
    <div class="page-header">
      <h1>Projects</h1>
      <p>View and manage active projects</p>
    </div>

    <div class="projects-container">
      <p>Project management features will be integrated here.</p>
    </div>
  </main>
</Layout>

<style>
  main {
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem;
  }

  .page-header {
    margin-bottom: 2rem;
  }

  h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .projects-container {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 2rem;
  }
</style>
