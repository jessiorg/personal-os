---
const { title = 'Todo' } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <style>
      :root {
        color-scheme: light;
        --bg: #ffffff;
        --surface: #fafafa;
        --surface-strong: #f4f4f5;
        --border: #e5e7eb;
        --text: #111111;
        --muted: #6b7280;
        --accent: #0f172a;
        --radius: 14px;
        --measure: 74rem;
      }

      html, body {
        margin: 0;
        min-height: 100%;
        background: var(--bg);
        color: var(--text);
        font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      }

      body {
        padding: 1.5rem;
      }

      main {
        max-width: var(--measure);
        margin: 0 auto;
      }

      a {
        color: inherit;
        text-decoration: none;
      }
    </style>
  </head>
  <body>
    <main>
      <slot />
    </main>
  </body>
</html>
