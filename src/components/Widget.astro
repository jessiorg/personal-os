---
interface Props {
  title: string;
  description: string;
  icon: string;
  href: string;
}

const { title, description, icon, href } = Astro.props;
---

<a class="widget" href={href}>
  <div class="widget-icon">{icon}</div>
  <div class="widget-content">
    <h3>{title}</h3>
    <p>{description}</p>
  </div>
</a>

<style>
  .widget {
    display: flex;
    gap: 1rem;
    padding: 1.5rem;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    transition: all 0.3s ease;
    text-decoration: none;
    color: inherit;
  }

  .widget:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.1);
    border-color: var(--color-primary);
  }

  .widget-icon {
    font-size: 2.5rem;
    flex-shrink: 0;
  }

  .widget-content {
    flex: 1;
  }

  h3 {
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
    color: var(--color-text);
  }

  p {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.4;
  }
</style>
